# Matrix homeserver base URL (where bot connects to Matrix C-S API)
MATRIX_HOMESERVER=https://your-matrix-server.example.com
# Matrix bot access token (secret; create in your Matrix client/account settings)
MATRIX_ACCESS_TOKEN=your_access_token_here
# Matrix user id of the bot account
MATRIX_USER_ID=@username:your-matrix-server.example.com
# Matrix device id used by the bot session
MATRIX_DEVICE_ID=redmine_bot

# Redmine base URL (API source for issues/journals)
REDMINE_URL=https://your-redmine.example.com
# Redmine API key (secret; from user profile)
REDMINE_API_KEY=your_api_key_here

# Scheduler timezone for dates/reminders
BOT_TIMEZONE=Europe/Moscow

# PostgreSQL username
POSTGRES_USER=bot
# PostgreSQL password (secret)
POSTGRES_PASSWORD=change-me
# URL-encoded POSTGRES_PASSWORD for safe DATABASE_URL construction in docker compose
POSTGRES_PASSWORD_URLENC=change-me
# PostgreSQL database name
POSTGRES_DB=redmine_matrix
# PostgreSQL host inside docker network
POSTGRES_HOST=postgres
# PostgreSQL port inside docker network
POSTGRES_PORT=5432

# Comma-separated admin emails allow-list for admin UI
ADMIN_EMAILS=dmitry@example.com
# Allow first logged-in email to become admin (0=off, 1=on)
ADMIN_BOOTSTRAP_FIRST_ADMIN=0
# Host port for admin UI
ADMIN_PORT=8080
# Session cookie name for admin UI
ADMIN_SESSION_COOKIE=admin_session
# CSRF cookie name for admin UI
ADMIN_CSRF_COOKIE=admin_csrf
# Cache TTL for admin_exists checks (seconds)
ADMIN_EXISTS_CACHE_TTL_SECONDS=20
# Cache TTL for integration-status warning checks (seconds)
INTEGRATION_STATUS_CACHE_TTL_SECONDS=30
# Content-Security-Policy для HTML: 1 = встроенная политика под CDN (htmx, FA, fonts) и inline script/style в шаблонах
# ADMIN_ENABLE_CSP=0
# Полная строка политики вместо встроенной (приоритет над ADMIN_ENABLE_CSP):
# ADMIN_CSP_POLICY=default-src 'self'; ...

# Salt used to hash auth tokens/codes in admin UI
AUTH_TOKEN_SALT=dev-change-me-in-prod
# TTL for admin UI session cookie (seconds)
SESSION_TTL_SECONDS=86400
# TTL for password reset token (seconds)
RESET_TOKEN_TTL_SECONDS=1800
# Cooldown between reset requests for same email (seconds)
RESET_COOLDOWN_SECONDS=90
# Use Secure cookie flag (set 1 in production with HTTPS)
COOKIE_SECURE=0
# Master key secret file path (32-byte key, docker mounted)
APP_MASTER_KEY_FILE=/run/secrets/app_master_key
# Fallback master key value for local/dev only (32 chars), keep empty in production
APP_MASTER_KEY=
# Show reset dev token in UI (dev/test only)
SHOW_DEV_TOKENS=0

# SMTP config for password reset email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=
SMTP_USE_TLS=0
SMTP_USE_STARTTLS=1
# Dev/test mode: no real email send, emulate success (production should be 0)
SMTP_MOCK=0
# SMTP network timeout (seconds)
SMTP_TIMEOUT_SECONDS=8
# Cache smtp health checks for N seconds
SMTP_HEALTH_TTL_SECONDS=300

# TTL for one-time Matrix room binding code (seconds)
MATRIX_CODE_TTL_SECONDS=300
# Echo matrix one-time code in UI for dev/testing
MATRIX_CODE_DEV_ECHO=0
# Comma-separated list of required integration secret names for onboarding
REQUIRED_SECRET_NAMES=REDMINE_URL,REDMINE_API_KEY,MATRIX_HOMESERVER,MATRIX_ACCESS_TOKEN,MATRIX_USER_ID,MATRIX_DEVICE_ID
