# ---------------------------------------------------------------------------
# Bootstrap-only environment template
# ---------------------------------------------------------------------------
# This file contains only infrastructure/bootstrap variables.
# Integration credentials (Redmine/Matrix) are expected to be entered
# in Admin UI -> Integrations and stored encrypted in DB.

# --- PostgreSQL bootstrap ---
POSTGRES_USER=bot
POSTGRES_PASSWORD=change-me
POSTGRES_PASSWORD_URLENC=change-me
POSTGRES_DB=redmine_matrix
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Admin app bootstrap ---
ADMIN_PORT=8080
ADMIN_EMAILS=
ADMIN_BOOTSTRAP_FIRST_ADMIN=0
ADMIN_SESSION_COOKIE=admin_session
ADMIN_CSRF_COOKIE=admin_csrf
ADMIN_SESSION_IDLE_TIMEOUT=1800
ADMIN_EXISTS_CACHE_TTL_SECONDS=20
INTEGRATION_STATUS_CACHE_TTL_SECONDS=30
AUTH_TOKEN_SALT=dev-change-me-in-prod
SESSION_TTL_SECONDS=86400
COOKIE_SECURE=0

# Master key used for encrypted app secrets in DB (required)
APP_MASTER_KEY_FILE=/run/secrets/app_master_key
# Dev fallback only; keep empty in production
APP_MASTER_KEY=

# --- Runtime options ---
BOT_TIMEZONE=Europe/Moscow
DOCKER_TARGET_SERVICE=bot
ADMIN_ENABLE_RUNTIME_OPS=0
BOT_RUNTIME_STATUS_FILE=/app/data/runtime_status.json
GROUP_REPEAT_SECONDS=1800

# Matrix room binding UX
MATRIX_CODE_TTL_SECONDS=300
MATRIX_CODE_DEV_ECHO=0

# Static assets version for cache bust
ADMIN_ASSET_VERSION=1

# Optional CSP
ADMIN_ENABLE_CSP=0
ADMIN_CSP_POLICY=

# Integration names required by onboarding wizard
REQUIRED_SECRET_NAMES=REDMINE_URL,REDMINE_API_KEY,MATRIX_HOMESERVER,MATRIX_ACCESS_TOKEN,MATRIX_USER_ID,MATRIX_DEVICE_ID

# --- Dev/Test only ---
# E2E_ADMIN_LOGIN=
# E2E_ADMIN_EMAIL=  # legacy alias
# E2E_ADMIN_PASSWORD=
