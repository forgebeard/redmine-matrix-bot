# =============================================================================
# Минимальная конфигурация для запуска.
#
# ПРИ ПЕРВОМ ЗАПУСКЕ:
#   docker compose up --build -d
# Сервис init автоматически создаст .env файл со случайными:
#   - POSTGRES_PASSWORD (пароль для PostgreSQL)
#   - APP_MASTER_KEY (мастер-ключ для шифрования секретов в БД)
#
# ВСЕ ОСТАЛЬНЫЕ ПАРАМЕТРЫ (Matrix, Redmine, таймзоны) настраиваются
# через GUI админки: http://localhost:8080/onboarding
# =============================================================================

# PostgreSQL password (генерируется автоматически при первом запуске)
POSTGRES_PASSWORD=

# Master key для шифрования секретов (генерируется автоматически при первом запуске)
APP_MASTER_KEY=

# ---------------------------------------------------------------------------
# Опционально: можно переопределить эти значения (по умолчанию указаны в скобках)
# ---------------------------------------------------------------------------
# Пользователи бота, маршруты статус→комната и версий задаются только в панели (PostgreSQL).
# Переменные USERS / STATUS_ROOM_MAP / VERSION_ROOM_MAP не читаются приложением — не задавайте их.
# POSTGRES_USER=bot
# POSTGRES_DB=via
# ADMIN_PORT=8080
# BOT_TIMEZONE=Europe/Moscow
# PORTAL_BASE_URL=https://redmine.example.com
# POLLING_INTERVAL_SEC=90
# DEDUP_TTL_HOURS=24
# SUBJECT_MAX_LEN=180

# ---------------------------------------------------------------------------
# Уведомления Matrix (tpl v2 из БД / templates/bot)
# ---------------------------------------------------------------------------
# Тело сообщений собирается через tpl_* и таблицу notification_templates
# (нужна рабочая БД в цикле бота).

# ---------------------------------------------------------------------------
# Docker runtime-control (не требуется менять в большинстве случаев)
# ---------------------------------------------------------------------------
# DOCKER_HOST=tcp://docker-socket-proxy:2375
# DOCKER_TARGET_SERVICE=bot
# BOT_RUNTIME_STATUS_FILE=/app/data/runtime_status.json

# ---------------------------------------------------------------------------
# Admin panel settings
# ---------------------------------------------------------------------------
# ADMIN_LOGINS=
# ADMIN_BOOTSTRAP_FIRST_ADMIN=0
# ADMIN_SESSION_COOKIE=admin_session
# ADMIN_CSRF_COOKIE=admin_csrf
# ADMIN_SESSION_IDLE_TIMEOUT=1800
# ADMIN_EXISTS_CACHE_TTL_SECONDS=20
# INTEGRATION_STATUS_CACHE_TTL_SECONDS=30
# ADMIN_ENABLE_CSP=0
# ADMIN_CSP_POLICY=
# ADMIN_ASSET_VERSION=
# ADMIN_EVENTS_LOG_PATH=
# ADMIN_EVENTS_LOG_SCAN_BYTES=
# ADMIN_EVENTS_LOG_PARSE_AS_UTC=1
# ADMIN_EVENTS_LOG_CRUD=0
# ADMIN_AUDIT_CRUD_DB=
# ADMIN_AUDIT_LOG_PATH=

# ---------------------------------------------------------------------------
# Auth / Security
# ---------------------------------------------------------------------------
# AUTH_TOKEN_SALT=dev-change-me-in-prod
# SESSION_TTL_SECONDS=86400
# RESET_TOKEN_TTL_SECONDS=1800
# RESET_COOLDOWN_SECONDS=90
# COOKIE_SECURE=0
# SHOW_DEV_TOKENS=0

# ---------------------------------------------------------------------------
# Matrix / Redmine settings (настраиваются через GUI: /onboarding)
# ---------------------------------------------------------------------------
# Эти параметры больше не задаются в .env!
# Откройте админку → Настройки → Параметры сервиса
# и введите:
#   - Адрес Redmine
#   - API-ключ Redmine
#   - Адрес Matrix
#   - Имя учётной записи Matrix
#   - Токен Matrix
#
# Hot reload: периодически подгружать пользователей/шаблоны/интервалы из БД без рестарта
# BOT_HOT_RELOAD=1
# BOT_HOT_RELOAD_INTERVAL_SEC=45
