# =============================================================================
# Опциональные переменные для docker compose и локального запуска.
#
# Секреты Postgres в репозиторий не кладём: в Docker пароль создаётся в томе
# (см. docker-compose.yml, сервис postgres-password-init). Показать пароль
# для DBeaver: админка → «Пароль PostgreSQL» на обзоре.
#
# Интеграции Matrix / Redmine вводятся в веб-панели (онбординг / «Секреты»);
# переменные ниже — необязательный fallback для dev и CI.
#
# Скопировать при необходимости:
#   cp .env.example .env
# =============================================================================

# Порт веб-админки на хосте (compose подставляет в ports)
ADMIN_PORT=8080

# Имя пользователя и БД Postgres (должны совпадать с docker-compose, если меняете)
POSTGRES_USER=bot
POSTGRES_DB=redmine_matrix

# Внутри сети Docker порт Postgres всегда 5432; на хост смотрит проброс в compose.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Явный URL БД (локальный pytest, CI, или свой Postgres). Если задан — имеет приоритет
# над DATABASE_PASSWORD_FILE + POSTGRES_*.
# DATABASE_URL=postgresql://bot:postgres@127.0.0.1:5433/redmine_matrix

# Путь к файлу с паролем (в compose задаётся автоматически). Для ручного запуска:
# DATABASE_PASSWORD_FILE=/path/to/postgres_password

# Master key 32 символа (UTF-8). Если не задан — создаётся data/.app_master_key (см. .gitignore).
APP_MASTER_KEY=
APP_MASTER_KEY_FILE=/run/secrets/app_master_key
AUTO_MASTER_KEY_FILE=

# --- Необязательный fallback Matrix / Redmine (основной источник — БД app_secrets) ---
# MATRIX_HOMESERVER=
# MATRIX_ACCESS_TOKEN=
# MATRIX_USER_ID=
# MATRIX_DEVICE_ID=redmine_bot
# REDMINE_URL=
# REDMINE_API_KEY=

BOT_TIMEZONE=Europe/Moscow
ADMIN_SESSION_COOKIE=admin_session
ADMIN_CSRF_COOKIE=admin_csrf
ADMIN_SESSION_IDLE_TIMEOUT=1800
ADMIN_EXISTS_CACHE_TTL_SECONDS=20
INTEGRATION_STATUS_CACHE_TTL_SECONDS=30
AUTH_TOKEN_SALT=dev-change-me-in-prod
SESSION_TTL_SECONDS=86400
COOKIE_SECURE=0
ADMIN_ASSET_VERSION=1

CHECK_INTERVAL=90
REMINDER_AFTER=3600
BOT_RUNTIME_STATUS_FILE=/app/data/runtime_status.json
GROUP_REPEAT_SECONDS=1800
BOT_LEASE_TTL_SECONDS=300
LOG_TO_FILE=1

DOCKER_HOST=tcp://docker-socket-proxy:2375
DOCKER_TARGET_SERVICE=bot

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=
SMTP_USE_TLS=0
SMTP_USE_STARTTLS=1
SMTP_MOCK=0
SMTP_TIMEOUT_SECONDS=8
SMTP_HEALTH_TTL_SECONDS=300

MATRIX_CODE_TTL_SECONDS=300
MATRIX_CODE_DEV_ECHO=0

REQUIRED_SECRET_NAMES=REDMINE_URL,REDMINE_API_KEY,MATRIX_HOMESERVER,MATRIX_ACCESS_TOKEN,MATRIX_USER_ID,MATRIX_DEVICE_ID

# E2E Playwright
# E2E_ADMIN_LOGIN=
# E2E_ADMIN_PASSWORD=
# E2E_ADMIN_EMAIL=
