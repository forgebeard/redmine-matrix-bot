# Matrix homeserver base URL (where bot connects to Matrix C-S API)
MATRIX_HOMESERVER=https://your-matrix-server.example.com
# Matrix bot access token (secret; create in your Matrix client/account settings)
MATRIX_ACCESS_TOKEN=your_access_token_here
# Matrix user id of the bot account
MATRIX_USER_ID=@username:your-matrix-server.example.com
# Опционально: идентификатор устройства для Matrix-клиента (по умолчанию redmine_bot)
# MATRIX_DEVICE_ID=redmine_bot

# Redmine base URL (API source for issues/journals)
REDMINE_URL=https://your-redmine.example.com
# Redmine API key (secret; from user profile)
REDMINE_API_KEY=your_api_key_here

# Scheduler timezone for dates/reminders
BOT_TIMEZONE=Europe/Moscow

# Лог бота в файл (1) или только stdout контейнера (0) — см. README, раздел «Логи»
# LOG_TO_FILE=1
# Файл лога: пусто → data/bot.log от корня приложения; иначе относительный или абсолютный путь
# LOG_PATH=
# Ротация: максимальный размер текущего файла (байты) и число архивов bot.log.1 … (минимум 1)
# LOG_MAX_BYTES=5242880
# LOG_BACKUP_COUNT=5

# Онбординг в Matrix (личка с ботом: !start, шаги до записи в bot_users). Нужен тот же APP_MASTER_KEY (32 байта), что и у админки.
MATRIX_ONBOARDING_ENABLED=1
# Таймаут неактивной сессии онбординга (секунды)
MATRIX_ONBOARDING_SESSION_TTL=900

# PostgreSQL username
POSTGRES_USER=bot
# PostgreSQL password (secret)
POSTGRES_PASSWORD=change-me
# URL-encoded POSTGRES_PASSWORD for safe DATABASE_URL construction in docker compose
POSTGRES_PASSWORD_URLENC=change-me
# PostgreSQL database name
POSTGRES_DB=redmine_matrix
# PostgreSQL host inside docker network
POSTGRES_HOST=postgres
# PostgreSQL port inside docker network
POSTGRES_PORT=5432

# Comma-separated allowed admin panel logins (пусто = без ограничения)
ADMIN_LOGINS=
# Allow first logged-in user to become admin (0=off, 1=on)
ADMIN_BOOTSTRAP_FIRST_ADMIN=0
# Host port for admin UI
ADMIN_PORT=8080
# Session cookie name for admin UI
ADMIN_SESSION_COOKIE=admin_session
# CSRF cookie name for admin UI
ADMIN_CSRF_COOKIE=admin_csrf
# Idle timeout для admin сессии (секунды)
ADMIN_SESSION_IDLE_TIMEOUT=1800
# Cache TTL for admin_exists checks (seconds)
ADMIN_EXISTS_CACHE_TTL_SECONDS=20
# Cache TTL for integration-status warning checks (seconds)
INTEGRATION_STATUS_CACHE_TTL_SECONDS=30
# Content-Security-Policy для HTML: 1 = встроенная политика под CDN (htmx, FA, fonts) и inline script/style в шаблонах
ADMIN_ENABLE_CSP=0
# Полная строка политики вместо встроенной (приоритет над ADMIN_ENABLE_CSP); пусто = не задано
ADMIN_CSP_POLICY=
# Версия для query string у /static/admin/css/*.css (сброс кэша браузера после обновления стилей); пусто = авто
ADMIN_ASSET_VERSION=
# Файл лога для раздела «События» в админке (таблица + CSV по содержимому); пусто = data/bot.log от корня приложения.
# Операции Start/Stop/Restart из панели дописывают строки с префиксом [ADMIN] в этот файл (в Docker том data/ у сервиса admin должен быть с записью).
ADMIN_EVENTS_LOG_PATH=
# Максимум байт, читаемых с конца файла для /events (если файл больше — показывается хвост; фильтр по датам только по нему). Пусто в строке ниже → в коде 8388608 (8 МБ).
ADMIN_EVENTS_LOG_SCAN_BYTES=
# Отдельный файл журнала аудита панели (Docker + CRUD): строки с меткой [AUDIT]. Пусто = data/admin_audit.log. Отключить: - или none.
ADMIN_AUDIT_LOG_PATH=
# События: префикс времени в файле лога как UTC процесса в Docker (1) или уже в BOT_TIMEZONE (0). По умолчанию 1.
# ADMIN_EVENTS_LOG_PARSE_AS_UTC=1
# Дописывать в тот же файл строки CRUD (пользователи бота, группы, маршруты, «Мои настройки»): 1|true|yes|on. По умолчанию выкл.
# ADMIN_EVENTS_LOG_CRUD=0
# Те же CRUD-события в таблицу bot_ops_audit (action=ADMIN_CRUD). Не задано — как ADMIN_EVENTS_LOG_CRUD; 0 — только файл; 1 — писать в БД даже без файла.
# ADMIN_AUDIT_CRUD_DB=
# Для pytest tests/e2e/ (Playwright): явный вход, если в БД уже есть администратор
# E2E_ADMIN_LOGIN=
# E2E_ADMIN_PASSWORD=

# Salt used to hash auth tokens/codes in admin UI
AUTH_TOKEN_SALT=dev-change-me-in-prod
# TTL for admin UI session cookie (seconds)
SESSION_TTL_SECONDS=86400
# TTL for password reset token (seconds)
RESET_TOKEN_TTL_SECONDS=1800
# Cooldown between reset requests for the same login (seconds)
RESET_COOLDOWN_SECONDS=90
# Use Secure cookie flag (set 1 in production with HTTPS)
COOKIE_SECURE=0
# Master key secret file path (32-byte key, docker mounted)
APP_MASTER_KEY_FILE=/run/secrets/app_master_key
# Fallback master key value for local/dev only (32 chars), keep empty in production
APP_MASTER_KEY=
# Show reset dev token in UI (dev/test only)
SHOW_DEV_TOKENS=0
# Runtime-control: целевой сервис Docker Compose (start/stop/restart из UI)
DOCKER_TARGET_SERVICE=bot
# DOCKER_HOST: у контейнера admin в compose по умолчанию tcp://docker-socket-proxy:2375 (см. docker-compose.yml).
# Локальный запуск админки: tcp://127.0.0.1:2375 или unix socket через прокси.
# DOCKER_HOST=tcp://docker-socket-proxy:2375
# Таймаут HTTP к Docker API (сек). POST /stop ждёт остановки контейнера — не ставьте слишком мало (дефолт в коде: GET 30 c, stop 90 c).
# DOCKER_CONTROL_TIMEOUT=120
# Имя compose-проекта для фильтра контейнера (метка com.docker.compose.project). Если указано неверно,
# раньше UI не находил контейнер; теперь есть fallback по сервису. Всё же лучше совпадать с реальными метками
# или оставить пустым / не задавать.
# COMPOSE_PROJECT_NAME=
# Алиас для тех же целей (если используете вместо COMPOSE_PROJECT_NAME)
# DOCKER_COMPOSE_PROJECT=
# Уникальная подстрока в имени контейнера (docker ps --format '{{.Names}}'), если метки compose не подходят
# DOCKER_TARGET_CONTAINER_SUBSTRING=
# Runtime status файл цикла (читает admin на /)
BOT_RUNTIME_STATUS_FILE=/app/data/runtime_status.json
# Повтор группового уведомления о новой задаче (секунды)
GROUP_REPEAT_SECONDS=1800

# E2E Playwright: явные учётные данные, если в БД уже есть админ
# E2E_ADMIN_LOGIN=
# E2E_ADMIN_PASSWORD=

# Список имён секретов для шага «Настройки подключений» и баннера готовности (без MATRIX_DEVICE_ID)
REQUIRED_SECRET_NAMES=REDMINE_URL,REDMINE_API_KEY,MATRIX_HOMESERVER,MATRIX_ACCESS_TOKEN,MATRIX_USER_ID
# Дефолтный device_id для Matrix-клиента в админке, если MATRIX_DEVICE_ID не задан (редко нужно менять)
MATRIX_DEFAULT_DEVICE_ID=redmine_bot
